# Copy to .env.local and add your key.
# Without a key the app still runs (deterministic keyword fallback), but the
# graceful, natural answers come from the model.
ANTHROPIC_API_KEY=sk-ant-...
# optional, defaults to claude-haiku-4-5 (cheapest Claude; pennies for a POC)
ANTHROPIC_MODEL=claude-haiku-4-5
